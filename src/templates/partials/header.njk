<header>
  <div class="header__avatar">
    <img src="{{ assetPath }}img/user-photo.jpg" alt="person photo" width="54" height="54" class="avatar__img" />
  </div>
  <nav>
    <ul class="nav-list">
      <li>
        <a class="nav-link" href="{{ localePath }}#summary">Summary</a>
      </li>
      <li>
        <a class="nav-link" href="{{ localePath }}#achievements">Achievements</a>
      </li>
      <li>
        <a class="nav-link" href="{{ localePath }}#exp">Experience</a>
      </li>
      <li>
        <a class="nav-link" href="{{ localePath }}#education">Education</a>
      </li>
      <li>
        <a class="nav-link cert" href="{{ localePath }}certificates/">Certificates</a>
      </li>
    </ul>
  </nav>
  <label class="language-select" for="language-select" aria-label="Select language">
    <select
      id="language-select"
      name="language"
      class="language-select__control"
      data-language-select
      data-current-locale="{{ locale.code }}"
      data-current-route="{{ route.id }}"
    >
      {% for language in languageLinks %}
      <option value="{{ language.url }}" data-locale="{{ language.code }}" {% if language.code == locale.code %}selected{% endif %}>
        {{ language.shortLabel }}
      </option>
      {% endfor %}
    </select>
  </label>
  <button class="burger-btn">Menu</button>
</header>
