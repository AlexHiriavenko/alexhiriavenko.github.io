<head>
  <meta charset="utf-8" />
  <title>{{ title }}</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="{{ page.seo.description }}" />
  <meta name="robots" content="index, follow" />
  <meta name="author" content="{{ site.author }}" />
  <meta name="theme-color" content="{{ site.themeColor }}" />
  <link rel="canonical" href="{{ page.canonicalUrl }}" />
  <link rel="alternate" type="application/json" href="{{ site.url }}/resume.json" title="Alex Hiriavenko Resume JSON" />
  <link rel="alternate" type="application/pdf" href="{{ site.url }}/Alex_Hiriavenko_CV.pdf" title="Alex Hiriavenko CV PDF" />
  {% for alternate in page.alternateLinks %}
  <link rel="alternate" hreflang="{{ alternate.hreflang }}" href="{{ alternate.url }}" />
  {% endfor %}
  <link rel="alternate" hreflang="x-default" href="{{ page.xDefaultUrl }}" />
  <meta property="og:type" content="{{ page.ogType }}" />
  <meta property="og:title" content="{{ page.seo.title }}" />
  <meta property="og:description" content="{{ page.seo.description }}" />
  <meta property="og:url" content="{{ page.canonicalUrl }}" />
  <meta property="og:site_name" content="{{ site.name }}" />
  <meta property="og:image" content="{{ site.ogImage }}" />
  <meta property="og:image:width" content="{{ site.ogImageWidth }}" />
  <meta property="og:image:height" content="{{ site.ogImageHeight }}" />
  <meta property="og:image:alt" content="{{ site.ogImageAlt }}" />
  <meta property="og:locale" content="{{ locale.ogLocale }}" />
  {% for alternateOgLocale in page.alternateOgLocales %}
  <meta property="og:locale:alternate" content="{{ alternateOgLocale }}" />
  {% endfor %}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ page.seo.title }}" />
  <meta name="twitter:description" content="{{ page.seo.description }}" />
  <meta name="twitter:image" content="{{ site.ogImage }}" />
  <meta name="twitter:image:alt" content="{{ site.ogImageAlt }}" />
  <!-- JSON-LD graph: WebSite, ProfilePage, Person -->
  <script type="application/ld+json">
    {{ structuredData.graph | json | safe }}
  </script>
  {% include "partials/favicon.njk" %}
  <link href="{{ assetPath }}css/styles.min.css" rel="stylesheet" />
</head>
